# AI API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Audio & Transcription
DEEPGRAM_API_KEY=your_deepgram_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Media Ingestion
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_INSTAGRAM_HOST=instagram-social-api.p.rapidapi.com
RAPIDAPI_INSTAGRAM_ENDPOINT=/v1/post_info
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Video Generation
HEYGEN_API_KEY=your_heygen_api_key_here

# Cloud Storage
YANDEX_DISK_OAUTH_TOKEN=your_yandex_disk_oauth_token_here
YANDEX_DISK_TOKEN=
YANDEX_TOKEN=
YANDEX_DISK_PROJECT_FOLDER=Плати по миру
AUTOMATION_INTERNAL_TOKEN=change_me_for_internal_workers

# Database (PostgreSQL)
DB_HOST=localhost
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_db_password_here
DB_PORT=5432

# Runtime
PORT=3000
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Final Video Automation
FINAL_VIDEO_PER_CLIENT_CONCURRENCY=1
FINAL_VIDEO_QUEUE_BACKLOG_PER_CLIENT=3
FINAL_VIDEO_SCHEDULER_BATCH_PER_CLIENT=1
FINAL_VIDEO_SCHEDULER_INTERVAL_SECONDS=60
FINAL_VIDEO_KIE_POLL_INTERVAL_SECONDS=30
FINAL_VIDEO_HEYGEN_POLL_INTERVAL_SECONDS=30
FINAL_VIDEO_RETRY_BASE_SECONDS=30
FINAL_VIDEO_RETRY_MAX_SECONDS=1800

# Other Configuration
INIT_DB=true
LOG_LEVEL=INFO
