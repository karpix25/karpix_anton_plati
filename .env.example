# LLM / Prompting
OPENROUTER_API_KEY=your_openrouter_api_key_here
SCENARIO_MODEL=google/gemini-2.5-flash
VISUAL_SEGMENTS_TEMPERATURE=0.1

# TTS / STT
DEEPGRAM_API_KEY=your_deepgram_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# TTS pause/silence cleanup controls
TTS_SILENCE_TRIM_ENABLED=true
TTS_SILENCE_TRIM_MIN_DURATION_SECONDS=0.35
TTS_SILENCE_TRIM_THRESHOLD_DB=-45
TTS_SENTENCE_TRIM_MIN_GAP_SECONDS=0.1
TTS_SENTENCE_TRIM_KEEP_GAP_SECONDS=0.06
TTS_PAUSE_TRIM_SILENCE_MIN_DURATION_SECONDS=0.04
TTS_PAUSE_TRIM_SILENCE_THRESHOLD_DB=-36
TTS_PAUSE_TRIM_MIN_OVERLAP_SECONDS=0.04
TTS_PAUSE_TRIM_MAX_REMOVAL_SHARE=0.20

# Scenario duration guardrails
SCENARIO_DURATION_OVERFLOW_TOLERANCE_SECONDS=3.0
SCENARIO_DURATION_REWRITE_MAX_ATTEMPTS=2

# B-roll / keyword extraction
BROLL_USE_SEMANTIC_KEYWORD_SELECTOR_V2=true

# Video providers
KIE_API_KEY=your_kie_api_key_here
# Optional legacy fallback for KIE key:
KIE_AI_API_KEY=
KIE_INTERNAL_RETRY_ATTEMPTS=3
KIE_INTERNAL_RETRY_DELAY_SECONDS=1.5
KIE_RESUBMIT_ATTEMPTS=2
FINAL_VIDEO_KIE_RESUBMIT_ATTEMPTS=2
HEYGEN_API_KEY=your_heygen_api_key_here

# Media ingestion / Telegram bot
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_INSTAGRAM_HOST=instagram-social-api.p.rapidapi.com
RAPIDAPI_INSTAGRAM_ENDPOINT=/v1/post_info
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional legacy fallbacks for token:
TELEGRAM_TOKEN=
BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_ADMIN_ID=
TELEGRAM_SUPER_ADMIN_IDS=
TELEGRAM_SUPER_ADMIN_ID=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
WEBAPP_BASE_URL=https://your-domain.com
UI_BASE_URL=

# Cloud storage (Yandex / S3)
YANDEX_DISK_OAUTH_TOKEN=your_yandex_disk_oauth_token_here
YANDEX_DISK_TOKEN=
YANDEX_TOKEN=
YANDEX_DISK_PROJECT_FOLDER=Плати по миру
S3_ENDPOINT=https://s3.your-provider.com
S3_REGION=us-east-1
S3_BUCKET=your_bucket_name
S3_BUCKET_NAME=your_bucket_name
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_PUBLIC_BASE_URL=https://s3.your-provider.com/your_bucket_name
S3_FORCE_PATH_STYLE=true

# Internal automation
AUTOMATION_INTERNAL_TOKEN=change_me_for_internal_workers
INTERNAL_API_BASE_URL=http://127.0.0.1:3000
FINAL_VIDEO_PER_CLIENT_CONCURRENCY=1
FINAL_VIDEO_QUEUE_BACKLOG_PER_CLIENT=3
FINAL_VIDEO_SCHEDULER_BATCH_PER_CLIENT=1
FINAL_VIDEO_SCHEDULER_INTERVAL_SECONDS=60
FINAL_VIDEO_KIE_POLL_INTERVAL_SECONDS=30
FINAL_VIDEO_HEYGEN_POLL_INTERVAL_SECONDS=30
FINAL_VIDEO_RETRY_BASE_SECONDS=30
FINAL_VIDEO_RETRY_MAX_SECONDS=1800
FINAL_VIDEO_WORKER_LEASE_SECONDS=3600
FINAL_VIDEO_WORKER_IDLE_SECONDS=10
FINAL_VIDEO_POLLER_LEASE_SECONDS=600
FINAL_VIDEO_POLLER_IDLE_SECONDS=10

# Database (PostgreSQL)
DB_HOST=localhost
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_db_password_here
DB_PORT=5432

# Runtime
PORT=3000
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
INIT_DB=true
LOG_LEVEL=INFO
